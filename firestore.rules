rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if user is owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if verifiedStatus is not modified
    function verifiedStatusUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verifiedStatus']);
    }

    // Helper to check if verifiedStatus is not set to 1 on create
    function verifiedStatusNotSetTo1OnCreate() {
      return !('verifiedStatus' in request.resource.data) || request.resource.data.verifiedStatus == 0;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && verifiedStatusNotSetTo1OnCreate();
      allow update: if isOwner(userId) && verifiedStatusUnchanged();
    }

    match /users/{userId}/contacts/{contactId} {
      allow read, write: if isOwner(userId);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);
      allow create: if isAuthenticated() && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);
      allow update: if isAuthenticated() && (chatId.split('_')[0] == request.auth.uid || chatId.split('_')[1] == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow get: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow list: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.resource.data.authorUid == request.auth.uid || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes'])
      );
      allow delete: if isAuthenticated() && resource.data.authorUid == request.auth.uid;
    }

    match /calls/{callId} {
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      
      match /callerCandidates/{id} {
        allow read, write: if isAuthenticated();
      }
      match /receiverCandidates/{id} {
        allow read, write: if isAuthenticated();
      }
    }
  }
}
